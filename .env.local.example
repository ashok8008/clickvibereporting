# MongoDB connection string
DATABASE_URL=mongodb://localhost:27017/clickvibe

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# App/dashboard URL shown in credential emails (https://app.clickvibe.ai in prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public base URL used to build tracking redirect links (https://trackcenter.info in prod)
NEXT_PUBLIC_TRACKING_BASE_URL=http://localhost:3000

# Resend (email). Leave blank locally — email sending is no-op without a key.
RESEND_API_KEY=
# Verified sender in Resend (domain must be verified in Resend dashboard)
RESEND_FROM_EMAIL=ClickVibe <onboarding@trackcenter.info>

# AppsFlyer Pull API V2 token — set in Vercel/host only, NEVER commit a real value
APPSFLYER_API_TOKEN=
APPSFLYER_DEFAULT_APP_ID=id6648798962

# Random secret to validate cron requests to /api/appsflyer/sync
CRON_SECRET=
